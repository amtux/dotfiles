# appearance
theme = Catppuccin Mocha
font-size = 14
macos-option-as-alt = true
unfocused-split-opacity=.8
scrollback-limit = 1_000_000

# keybinds
# clear all keybinds first
keybind=clear

# - generic
keybind = alt+r=reload_config
keybind = alt+a=select_all
keybind = super+c=copy_to_clipboard
keybind = alt+c=copy_to_clipboard
keybind = super+v=paste_from_clipboard
keybind = alt+v=paste_from_clipboard
keybind = super+shift+j=write_screen_file:paste
# -- font size (dont use -,+,0 its a pain)
keybind = alt+i=increase_font_size:1
keybind = alt+o=decrease_font_size:1
keybind = alt+p=reset_font_size
# quit keybind missing on purpose to avoid accidental quit

# - management
# -- tab
keybind = super+t=new_tab
keybind = super+w=close_tab
keybind = super+r=prompt_tab_title
# -- split
keybind = alt+shift+h=new_split:left
keybind = alt+shift+j=new_split:down
keybind = alt+shift+k=new_split:up
keybind = alt+shift+l=new_split:right
keybind = alt+z=toggle_split_zoom
keybind = alt+w=close_surface

# - move around in
# -- tabs
keybind = super+h=previous_tab
keybind = super+l=next_tab
# -- panes
keybind = alt+h=goto_split:left
keybind = alt+j=goto_split:bottom
keybind = alt+k=goto_split:top
keybind = alt+l=goto_split:right

# - resize
# -- tabs
keybind = super+alt+h=resize_split:left,50
keybind = super+alt+j=resize_split:down,50
keybind = super+alt+k=resize_split:up,50
keybind = super+alt+l=resize_split:right,50

# - navigate shell prompts (requires shell integration)
keybind = alt+up=jump_to_prompt:-1
keybind = alt+down=jump_to_prompt:1

# - misc
keybind = shift+enter=text:\n
